      "projects": ["WO", "OPT", "PROJ"],
      "skills": ["architecture", "harness", "automation"],
      "timezone": "UTC+2"
    }
  ],
  "projects": [
    {
      "id": "WO",
      "name": "WayOfWork Platform",
      "prefix": "WOW",
      "description": "Way of Work platform specifications (WOW-010 through WOW-016)",
      "members": ["craig", "josef", "andre", "tomas", "zerwiz"],
      "default_assignee": "zerwiz",
      "repositories": ["wayofmono/wayofmono"]
    },
    {
      "id": "OPT",
      "name": "Opticat Platform",
      "prefix": "OPT",
      "description": "Opticat platform (simulator, backend-integrator, ui-builder)",
      "members": ["craig", "zerwiz"],
      "default_assignee": "zerwiz",
      "repositories": ["wayofmono/opticat"]
    },
    {
      "id": "PROJ",
      "name": "WayOfMono Monorepo",
      "prefix": "PROJ",
      "description": "WayOfMono monorepo consolidation and tooling",
      "members": ["craig", "josef", "andre", "tomas", "zerwiz"],
      "default_assignee": "zerwiz",
      "repositories": ["wayofmono/wayofmono"]
    }
  ],
  "roles": {
    "cto": {
      "permissions": ["read-all", "write-all", "approve-reviews", "assign-any", "manage-team"],
      "description": "Chief Technology Officer - full access across all projects"
    },
    "lead": {
      "permissions": ["read-project", "write-project", "approve-reviews", "assign-project", "manage-skills"],
      "description": "Technical Lead - full access within assigned projects"
    },
    "senior": {
      "permissions": ["read-project", "write-assigned", "request-review", "create-tickets"],
      "description": "Senior Developer - works on assigned tickets within projects"
    },
    "junior": {
      "permissions": ["read-assigned", "write-assigned", "request-review", "create-personal-tickets"],
      "description": "Junior Developer - works on assigned tickets with guidance"
    }
  },
  "ticket_namespaces": {
    "WOW": { "project": "WO", "description": "Way of Work platform tickets" },
    "OPT": { "project": "OPT", "description": "Opticat platform tickets" },
    "PROJ": { "project": "PROJ", "description": "WayOfMono project tickets" },
    "TEAM": { "project": "TEAM", "description": "Team-specific tickets" }
  },
  "settings": {
    "auto_sync_personal_todos": true,
    "require_review_for": ["cto", "lead"],
    "github_integration": true,
    "notification_channels": ["github", "local"]
  }
}