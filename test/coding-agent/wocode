#!/bin/bash
# Launcher for project-local wocode
# This script ensures the local .wo directory is used for configuration.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_BIN="$SCRIPT_DIR/node_modules/.bin/wocode"

if [ ! -f "$LOCAL_BIN" ]; then
    echo "Error: wocode not found in node_modules/.bin"
    echo "Please run 'pnpm install' in $SCRIPT_DIR first."
    exit 1
fi

# Ensure local .wo is used even if WO_CODING_AGENT_DIR is not set
# (Though our recent code changes make this the default if .wo exists)
export WO_CODING_AGENT_DIR="$SCRIPT_DIR/.wo"

exec "$LOCAL_BIN" "$@"
