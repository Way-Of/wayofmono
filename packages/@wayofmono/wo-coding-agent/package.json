{
  "name": "@wayofmono/wo-coding-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "WayOfMono (Wo) Coding Agent — CLI harness for AI-assisted software development",
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "bin": {
    "wo": "./dist/esm/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": ["dist", "src", "package.json", "README.md"],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.wayofmono.dev"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@wayofmono/wo-agent-core": "workspace:*",
    "@wayofmono/wo-ai": "workspace:*",
    "@wayofmono/wo-tui": "workspace:*",
    "@wayofmono/telemetry": "workspace:*",
    "diff": "^7.0.0",
    "highlight.js": "^11.10.0",
    "hosted-git-info": "^7.0.0",
    "typebox": "^1.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earendil-works/wayofmono",
    "directory": "packages/@wayofmono/wo-coding-agent"
  },
  "homepage": "https://wayofmono.dev",
  "keywords": ["agent", "coding", "cli", "wayofmono", "wo"]
}
