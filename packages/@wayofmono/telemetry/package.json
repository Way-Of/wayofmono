  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerwiz/wayofmono",
    "directory": "packages/@wayofmono/telemetry"
