{
  "name": "@wayofmono/telemetry",
  "version": "1.0.0",
  "type": "module",
  "description": "WayOfMono ODD-first instrumentation and telemetry SDK — OpenTelemetry-based tracing for agent operations",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": ["src", "package.json", "README.md"],
  "publishConfig": {
    "access": "public",
