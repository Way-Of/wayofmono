{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@wayofmono/wo-ai": ["../wo-ai/src/index.ts"],
      "@wayofmono/wo-agent-core": ["../wo-agent-core/src/index.ts"],
      "@wayofmono/wo-tui": ["../wo-tui/src/index.ts"],
      "@wayofmono/telemetry": ["../telemetry/src/index.ts"]
    }
  },
  "include": ["src"]
}
