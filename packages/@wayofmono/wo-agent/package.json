{
  "name": "@wayofmono/wo-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "WayOfMono (Wo) Agent SDK — embeddable general-purpose AI agent for your applications",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./skills/*": {
      "types": "./src/skills/*.ts",
      "default": "./src/skills/*.ts"
    }
  },
  "files": ["src", "package.json", "README.md"],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.wayofmono.dev"
  },
  "scripts": {
    "build": "echo 'wo-agent is source-only; no build step needed'",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wayofmono/wo-agent-core": "workspace:*",
    "@wayofmono/wo-ai": "workspace:*",
    "@wayofmono/wo-tui": "workspace:*",
    "@wayofmono/telemetry": "workspace:*",
    "typebox": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerwiz/wayofmono",
    "directory": "packages/@wayofmono/wo-agent"
  },
  "homepage": "https://wayofmono.dev",
  "keywords": ["agent", "sdk", "ai", "wayofmono", "wo", "skills"]
}
