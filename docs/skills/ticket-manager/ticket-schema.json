{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ticket Schema",
  "description": "Validation contract for ticket data across all namespaces (WOW, OPT, PROJ, TEAM)",
  "type": "object",
  "required": ["title", "type", "priority", "status", "assignee", "namespace", "category"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Ticket title in format '[PREFIX-XXX] Description'",
      "pattern": "^\\[(WOW|OPT|PROJ|TEAM)-\\d+\\] .+$"
    },
    "type": {
      "type": "string",
      "enum": ["Feature", "Bug", "Chore", "Improvement", "Documentation", "Security"],
      "description": "Type of ticket"
    },
    "priority": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"],
      "description": "Priority level"
    },
    "status": {
      "type": "string",
      "enum": ["Backlog", "Planned", "Ready", "In Progress", "Submitted for Review", "Changes Requested", "Approved", "Done", "Blocked"],
      "description": "Current status in the workflow"
    },
    "assignee": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$",
      "description": "Assigned developer (e.g., @zerwiz)"
    },
    "reporter": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$",
      "description": "Person who created the ticket"
    },
    "project": {
      "type": "string",
      "enum": ["WO", "OPT", "PROJ", "TEAM"],
      "description": "Project the ticket belongs to"
    },
    "namespace": {
      "type": "string",
      "enum": ["wow", "opticat", "proj", "team"],
      "description": "Namespace for the ticket"
    },
    "category": {
      "type": "string",
      "enum": ["frontend", "backend", "architecture", "infrastructure", "communications", "ai-agents", "testing", "documentation", "security", "performance", "system"],
      "description": "Technical category"
    },
    "role_required": {
      "type": "string",
      "enum": ["cto", "lead", "senior", "junior"],
      "description": "Minimum role required to work on this ticket"
    },
    "parent_ticket": {
      "type": "string",
      "pattern": "^(WOW|OPT|PROJ|TEAM)-\\d+$",
      "description": "Parent shared ticket ID for personal tickets"
    },
    "shared_tickets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(WOW|OPT|PROJ|TEAM)-\\d+$"
      },
      "description": "Shared ticket IDs linked to a personal ticket"
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "pattern": "^(WOW|OPT|PROJ|TEAM)-\\d+$" },
      "description": "Tickets that block this one"
    },
    "unblocks": {
      "type": "array",
      "items": { "type": "string", "pattern": "^(WOW|OPT|PROJ|TEAM)-\\d+$" },
      "description": "Tickets unblocked by this one"
    },
    "pr_url": {
      "type": "string",
      "format": "uri",
      "description": "Link to GitHub PR"
    },
    "github_issue": {
      "type": "string",
      "format": "uri",
      "description": "Link to GitHub issue"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)"
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date (YYYY-MM-DD)"
    },
    "reviewed_by": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$",
      "description": "CTO/Lead who reviewed"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date",
      "description": "Review date (YYYY-MM-DD)"
    }
  }
}
